# Copia este archivo como .env y rellena los valores reales.
# NUNCA comitas el .env al repositorio.

# Django
DJANGO_SECRET_KEY=django-insecure-replace-me-with-a-50-char-random-string
DJANGO_DEBUG=False

# Base de datos (PostgreSQL en producción)
# Formato: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://divinity:password@localhost:5432/divinity_db

# Desarrollo local (SQLite — omitir en producción)
# DATABASE_URL=sqlite:///db.sqlite3
